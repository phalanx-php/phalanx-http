{
    "name": "phalanx-php/http",
    "description": "HTTP server framework for Phalanx",
    "license": "MIT",
    "type": "library",
    "keywords": [
        "http",
        "server",
        "routing",
        "async",
        "fastroute",
        "swoole"
    ],
    "homepage": "https://github.com/phalanx-php/phalanx-http",
    "authors": [
        {
            "name": "Jonathan Havens",
            "email": "mail@phalanx-php.com"
        }
    ],
    "support": {
        "source": "https://github.com/phalanx-php/phalanx-http"
    },
    "require": {
        "php": "^8.4",
        "guzzlehttp/psr7": "^2.0",
        "nikic/fast-route": "^2.0",
        "ext-swoole": "^6.0",
        "phalanx-php/runtime": "^0.7"
    },
    "suggest": {
        "symfony/runtime": "For Symfony Runtime integration via Http::starting()",
        "phalanx-php/worker": "For worker process parallelism in request handlers"
    },
    "require-dev": {
        "phalanx-php/http-client": "^0.7",
        "phpunit/phpunit": "^13.0",
        "spatie/ignition": "^1.15"
    },
    "archive": {
        "exclude": [
            "/.aimind",
            "/.aimind/**",
            "/.claude",
            "/.claude/**",
            "/.daemon8",
            "/.daemon8/**",
            "/.DS_Store",
            "/.env*",
            "/**/.env*",
            "/.gitattributes",
            "/.github",
            "/.github/**",
            "/.gitignore",
            "/**/.gitignore",
            "/.idea",
            "/.idea/**",
            "/.php-cs-fixer.cache",
            "/.phpstan-cache",
            "/.phpstan-cache/**",
            "/.phpunit.result.cache",
            "/brand",
            "/brand/**",
            "/demos",
            "/demos/**",
            "/docs",
            "/docs/**",
            "/examples",
            "/examples/**",
            "/phpcs.xml",
            "/phpstan.neon",
            "/phpunit.xml",
            "/phpunit.xml.dist",
            "/rector.php",
            "/SPEC.md",
            "/tests",
            "/tests/**",
            "/tmp",
            "/tmp/**",
            "/tools",
            "/tools/**",
            "/vendor",
            "/vendor/**"
        ]
    },
    "scripts": {
        "test": "php -d memory_limit=512M vendor/bin/phpunit -c phpunit.xml"
    },
    "autoload": {
        "psr-4": {
            "Phalanx\\Http\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Phalanx\\Http\\Tests\\": "tests/"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-main": "0.7.x-dev"
        },
        "phalanx": {
            "bundles": [
                "Phalanx\\Http\\Testing\\TestableBundle"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
